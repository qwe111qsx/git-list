{
  "name": "git-list",
  "displayName": "%git-list.displayName%",
  "description": "%git-list.description%",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:gitListView",
    "onCommand:gitList.clearAuthorColors"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%git-list.config.title%",
      "properties": {
        "git-list.commitsPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.commitsPageSize%"
        },
        "git-list.stashPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.stashPageSize%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-list",
          "title": "%git-list.viewContainer.title%",
          "icon": "media/git-list.svg"
        }
      ]
    },
    "views": {
      "git-list": [
        {
          "id": "gitListView",
          "name": "%git-list.view.name%",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "gitList.refresh",
        "title": "%git-list.command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.clearAuthorColors",
        "title": "%git-list.command.clearAuthorColors%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitList.refresh",
          "when": "view == gitListView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
