{
  "name": "git-list",
  "displayName": "Git List",
  "description": "Sidebar: commits, file history, branches, remotes, stashes — browse files and open diffs; paging, refresh, fetch, stash and branch actions.",
  "version": "0.0.12",
  "author": "liuyuanfan",
  "publisher": "liuyuanfan",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/liuyuanfan6/git-list.git"
  },
  "bugs": {
    "url": "https://gitee.com/liuyuanfan6/git-list/issues"
  },
  "keywords": [
    "git",
    "scm",
    "commits",
    "stash",
    "sidebar",
    "history",
    "diff"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:gitListView",
    "onCommand:gitList.clearAuthorColors",
    "onCommand:gitList.openPatchFileInWorkspace",
    "onCommand:gitList.openWorkingTreeFromDiff",
    "onCommand:gitList.refreshFileHistory",
    "onCommand:gitList.loadMoreFileHistoryCommits",
    "onCommand:gitList.refreshCommits",
    "onCommand:gitList.refreshStash",
    "onCommand:gitList.createBranchFromCommit",
    "onCommand:gitList.refreshBranches",
    "onCommand:gitList.refreshBranchCommits",
    "onCommand:gitList.refreshRemotes",
    "onCommand:gitList.refreshRemoteBranches",
    "onCommand:gitList.loadMoreBranchCommits",
    "onCommand:gitList.loadMoreRemotes",
    "onCommand:gitList.loadMoreRemoteBranches",
    "onCommand:gitList.applyStash",
    "onCommand:gitList.dropStash",
    "onCommand:gitList.loadMoreBranches",
    "onCommand:gitList.deleteBranch",
    "onCommand:gitList.deleteBranchesOlderThanSixMonths",
    "onCommand:gitList.openBranchesMoreActions",
    "onCommand:gitList.mergeBranchIntoHead",
    "onCommand:gitList.checkoutBranch",
    "onCommand:gitList.showRepoGitStatus",
    "onCommand:gitList.abortMerge",
    "onCommand:gitList.abortRebase",
    "onCommand:gitList.openCursorLineCommitFileDiff"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%git-list.config.title%",
      "properties": {
        "git-list.commitsPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.commitsPageSize%"
        },
        "git-list.stashPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.stashPageSize%"
        },
        "git-list.branchesPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.branchesPageSize%"
        },
        "git-list.remotesPageSize": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.remotesPageSize%"
        },
        "git-list.showCursorLineGitHint": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%git-list.config.showCursorLineGitHint%"
        },
        "git-list.cursorLineGitHintPreloadMaxLines": {
          "type": "number",
          "default": 400,
          "minimum": 0,
          "maximum": 20000,
          "markdownDescription": "%git-list.config.cursorLineGitHintPreloadMaxLines%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-list",
          "title": "%git-list.viewContainer.title%",
          "icon": "media/git-list.svg"
        }
      ]
    },
    "views": {
      "git-list": [
        {
          "id": "gitListView",
          "name": "%git-list.view.name%",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "gitList.refresh",
        "title": "%git-list.command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.openPatchFileInWorkspace",
        "title": "%git-list.command.openPatchFileInWorkspace%",
        "icon": "$(file)"
      },
      {
        "command": "gitList.openWorkingTreeFromDiff",
        "title": "%git-list.command.openWorkingTreeFromDiff%",
        "icon": "$(file)"
      },
      {
        "command": "gitList.refreshFileHistory",
        "title": "%git-list.command.refreshFileHistory%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.loadMoreFileHistoryCommits",
        "title": "Git List: Load more file history"
      },
      {
        "command": "gitList.refreshCommits",
        "title": "%git-list.command.refreshCommits%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.refreshStash",
        "title": "%git-list.command.refreshStash%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.refreshBranches",
        "title": "%git-list.command.refreshBranches%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.refreshBranchCommits",
        "title": "%git-list.command.refreshBranchCommits%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.refreshRemotes",
        "title": "%git-list.command.refreshRemotes%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.refreshRemoteBranches",
        "title": "%git-list.command.refreshRemoteBranches%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.clearAuthorColors",
        "title": "%git-list.command.clearAuthorColors%"
      },
      {
        "command": "gitList.createBranchFromCommit",
        "title": "%git-list.command.createBranchFromCommit%"
      },
      {
        "command": "gitList.applyStash",
        "title": "%git-list.command.applyStash%"
      },
      {
        "command": "gitList.dropStash",
        "title": "%git-list.command.dropStash%"
      },
      {
        "command": "gitList.deleteBranch",
        "title": "%git-list.command.deleteBranch%"
      },
      {
        "command": "gitList.deleteBranchesOlderThanSixMonths",
        "title": "%git-list.command.deleteBranchesOlderThanSixMonths%"
      },
      {
        "command": "gitList.openBranchesMoreActions",
        "title": "%git-list.command.openBranchesMoreActions%",
        "icon": "$(kebab-horizontal)"
      },
      {
        "command": "gitList.mergeBranchIntoHead",
        "title": "%git-list.command.mergeBranchIntoHead%"
      },
      {
        "command": "gitList.checkoutBranch",
        "title": "%git-list.command.checkoutBranch%"
      },
      {
        "command": "gitList.showRepoGitStatus",
        "title": "%git-list.command.showRepoGitStatus%"
      },
      {
        "command": "gitList.abortMerge",
        "title": "%git-list.command.abortMerge%"
      },
      {
        "command": "gitList.abortRebase",
        "title": "%git-list.command.abortRebase%"
      },
      {
        "command": "gitList.openCursorLineCommitFileDiff",
        "title": "%git-list.command.openCursorLineCommitFileDiff%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gitList.openWorkingTreeFromDiff",
          "when": "gitList.isGitListDiff",
          "group": "navigation@8"
        }
      ],
      "view/title": [
        {
          "command": "gitList.refresh",
          "when": "view == gitListView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gitList.refreshCommits",
          "when": "view == gitListView && viewItem == gitListSectionCommits",
          "group": "inline"
        },
        {
          "command": "gitList.refreshFileHistory",
          "when": "view == gitListView && viewItem == gitListSectionFileHistory",
          "group": "inline"
        },
        {
          "command": "gitList.refreshStash",
          "when": "view == gitListView && viewItem == gitListSectionStash",
          "group": "inline"
        },
        {
          "command": "gitList.refreshBranches",
          "when": "view == gitListView && viewItem == gitListSectionBranches",
          "group": "inline@1"
        },
        {
          "command": "gitList.openBranchesMoreActions",
          "when": "view == gitListView && viewItem == gitListSectionBranches",
          "group": "inline@2"
        },
        {
          "command": "gitList.refreshBranchCommits",
          "when": "view == gitListView && (viewItem == gitListBranch || viewItem == gitListBranchUnmerged || viewItem == gitListRemoteBranch || viewItem == gitListRemoteBranchUnmerged)",
          "group": "inline"
        },
        {
          "command": "gitList.refreshRemotes",
          "when": "view == gitListView && viewItem == gitListSectionRemotes",
          "group": "inline"
        },
        {
          "command": "gitList.refreshRemoteBranches",
          "when": "view == gitListView && viewItem == gitListRemote",
          "group": "inline"
        },
        {
          "command": "gitList.openPatchFileInWorkspace",
          "when": "view == gitListView && viewItem == gitListPatchFile",
          "group": "inline"
        },
        {
          "command": "gitList.createBranchFromCommit",
          "when": "view == gitListView && viewItem == gitListCommit",
          "group": "1_git"
        },
        {
          "command": "gitList.applyStash",
          "when": "view == gitListView && viewItem == gitListStash",
          "group": "1_git"
        },
        {
          "command": "gitList.dropStash",
          "when": "view == gitListView && viewItem == gitListStash",
          "group": "1_git"
        },
        {
          "command": "gitList.checkoutBranch",
          "when": "view == gitListView && (viewItem == gitListBranch || viewItem == gitListBranchUnmerged || viewItem == gitListRemoteBranch || viewItem == gitListRemoteBranchUnmerged)",
          "group": "1_git"
        },
        {
          "command": "gitList.mergeBranchIntoHead",
          "when": "view == gitListView && (viewItem == gitListBranchUnmerged || viewItem == gitListRemoteBranchUnmerged)",
          "group": "1_git"
        },
        {
          "command": "gitList.deleteBranch",
          "when": "view == gitListView && (viewItem == gitListBranch || viewItem == gitListBranchUnmerged)",
          "group": "1_git"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "render-icon": "node scripts/render-icon-png.mjs",
    "package": "npm run compile && npm run render-icon && vsce package",
    "release": "node scripts/release.mjs patch"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.8.0",
    "ovsx": "^0.10.4",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  }
}
