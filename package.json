{
  "name": "git-list",
  "displayName": "%git-list.displayName%",
  "description": "%git-list.description%",
  "version": "0.0.1",
  "author": "liuyuanfan",
	"publisher": "liuyuanfan",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/liuyuanfan6/git-list.git"
  },
  "bugs": {
    "url": "https://gitee.com/liuyuanfan6/git-list/issues"
  },
  "keywords": [
    "git",
    "scm",
    "commits",
    "stash",
    "sidebar",
    "history",
    "diff"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onView:gitListView",
    "onCommand:gitList.clearAuthorColors",
    "onCommand:gitList.openSupportPage"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%git-list.config.title%",
      "properties": {
        "git-list.commitsPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.commitsPageSize%"
        },
        "git-list.stashPageSize": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "%git-list.config.stashPageSize%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-list",
          "title": "%git-list.viewContainer.title%",
          "icon": "media/git-list.svg"
        }
      ]
    },
    "views": {
      "git-list": [
        {
          "id": "gitListView",
          "name": "%git-list.view.name%",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "gitList.refresh",
        "title": "%git-list.command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitList.clearAuthorColors",
        "title": "%git-list.command.clearAuthorColors%"
      },
      {
        "command": "gitList.openSupportPage",
        "title": "%git-list.command.openSupportPage%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitList.refresh",
          "when": "view == gitListView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "render-icon": "node scripts/render-icon-png.mjs",
    "package": "npm run compile && npm run render-icon && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.8.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  }
}
